@page
@model myApp.Areas.Admin.Pages.Products.CreateModel
@{
    ViewData["Title"] = "Create Product";
}

<h2 class="mb-3">Create Product</h2>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Produit.Nom" class="form-label"></label>
        <input asp-for="Produit.Nom" class="form-control" />
        <span asp-validation-for="Produit.Nom" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Produit.Prix" class="form-label"></label>
        <input asp-for="Produit.Prix" class="form-control" />
        <span asp-validation-for="Produit.Prix" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Produit.CategorieId" class="form-label">Category</label>
        <select asp-for="Produit.CategorieId" asp-items="Model.Categories" class="form-select"></select>
        <span asp-validation-for="Produit.CategorieId" class="text-danger"></span>
    </div>

    <button type="submit" name="mode" value="new" class="btn btn-primary">Save & Add Another</button>
    <button type="submit" name="mode" value="list" class="btn btn-outline-primary">Save & View Products</button>
    <a asp-page="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
