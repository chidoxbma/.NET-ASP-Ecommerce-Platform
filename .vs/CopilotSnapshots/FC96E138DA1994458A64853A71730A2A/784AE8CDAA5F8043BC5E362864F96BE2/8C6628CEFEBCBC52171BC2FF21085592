@model myApp.Areas.Client.ViewModels.ProduitIndexViewModel

@{
    ViewData["Title"] = "Produits";
}

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
        <h2 class="mb-0">Client - Produits</h2>

        <form method="get" asp-area="Client" asp-controller="Produit" asp-action="Index" class="d-flex align-items-center gap-2">
            <label for="categorieId" class="form-label mb-0">Categorie</label>
            <select id="categorieId" name="categorieId" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">Toutes les categories</option>
                @foreach (var categorie in Model.Categories)
                {
                    if (Model.SelectedCategorieId == categorie.Id)
                    {
                        <option value="@categorie.Id" selected>@categorie.Nom</option>
                    }
                    else
                    {
                        <option value="@categorie.Id">@categorie.Nom</option>
                    }
                }
            </select>
        </form>
    </div>

    <div class="row g-3">
        @foreach (var produit in Model.Produits)
        {
            <div class="col-12 col-sm-6 col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@produit.Nom</h5>
                        <p class="card-text mb-1"><strong>Prix:</strong> @produit.Prix</p>
                        <p class="card-text text-muted mb-3"><strong>Categorie:</strong> @produit.Categorie?.Nom</p>

                        <div class="mt-auto d-flex flex-wrap gap-2 align-items-center">
                            <a asp-area="Client"
                               asp-controller="Produit"
                               asp-action="Details"
                               asp-route-id="@produit.Id"
                               class="btn btn-outline-primary btn-sm">View Details</a>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form method="post" asp-area="Client" asp-controller="Panier" asp-action="Add" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="produitId" value="@produit.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">Login to add to cart</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@using System.ComponentModel.DataAnnotations
@using myApp.Data

@{
    public class CheckoutViewModel
    {
        [Required]
        public string NomComplet { get; set; } = string.Empty;

        [Required]
        public string AdresseLivraison { get; set; } = string.Empty;

        [Required]
        public string VilleLivraison { get; set; } = string.Empty;

        public Panier? Panier { get; set; }
    }
}
