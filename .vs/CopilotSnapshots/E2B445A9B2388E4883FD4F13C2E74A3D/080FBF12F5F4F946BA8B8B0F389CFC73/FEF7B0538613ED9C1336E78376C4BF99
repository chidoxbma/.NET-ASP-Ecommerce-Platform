@model myApp.Models.Produit

@{
    ViewData["Title"] = "Détails produit";
}

<h2>Détails du produit</h2>

<div>
    <p><strong>Nom:</strong> @Model.Nom</p>
    <p><strong>Prix:</strong> @Model.Prix</p>
    <p><strong>Catégorie:</strong> @Model.Categorie?.Nom</p>
</div>

<a asp-area="Client" asp-controller="Produit" asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
