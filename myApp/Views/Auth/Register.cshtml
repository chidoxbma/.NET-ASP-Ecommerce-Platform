@{
    ViewData["Title"] = "Register";
}

<section class="auth-shell">
    <div class="auth-card card p-4 p-md-5">
        <h2 class="mb-2">Create your account</h2>
        <p class="mb-4">Join <strong>RachidShop</strong> and start exploring premium products.</p>

        @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "text-danger mb-3" })

        <form method="post" asp-controller="Auth" asp-action="Register">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label for="nomComplet" class="form-label">Full Name</label>
                <input id="nomComplet" name="nomComplet" type="text" class="form-control" placeholder="Your full name" required />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required />
            </div>

            <div class="mb-3">
                <label for="motDePasse" class="form-label">Password</label>
                <input id="motDePasse" name="motDePasse" type="password" class="form-control" placeholder="Create a strong password" required />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label for="telephone" class="form-label">Phone Number</label>
                    <input id="telephone" name="telephone" type="tel" class="form-control" placeholder="Optional" />
                </div>
                <div class="col-md-6">
                    <label for="ville" class="form-label">City</label>
                    <input id="ville" name="ville" type="text" class="form-control" placeholder="Optional" />
                </div>
            </div>

            <div class="mb-4">
                <label for="adresse" class="form-label">Address</label>
                <input id="adresse" name="adresse" type="text" class="form-control" placeholder="Optional" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Register</button>
        </form>

        <p class="mt-4 mb-0 text-center">
            Already have an account?
            <a asp-controller="Auth" asp-action="Login">Login here</a>
        </p>
    </div>
</section>
