@{
    ViewData["Title"] = "Login";
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
}

<section class="auth-shell">
    <div class="auth-card card p-4 p-md-5">
        <h2 class="mb-2">Welcome back</h2>
        <p class="mb-4">Sign in to continue shopping on <strong>RachidShop</strong>.</p>

        @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "text-danger mb-3" })

        <form method="post" asp-controller="Auth" asp-action="Login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required />
            </div>

            <div class="mb-4">
                <label for="motDePasse" class="form-label">Password</label>
                <input id="motDePasse" name="motDePasse" type="password" class="form-control" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>

        <p class="mt-4 mb-0 text-center">
            Don’t have an account?
            <a asp-controller="Auth" asp-action="Register">Create one</a>
        </p>
    </div>
</section>
