@{
    ViewData["Title"] = "Login";
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
}

<h2>Login</h2>

@Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "text-danger" })

<form method="post" action="/Auth/Login">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />

    <div class="mb-3">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" class="form-control" required />
    </div>

    <div class="mb-3">
        <label for="motDePasse">Password</label>
        <input id="motDePasse" name="motDePasse" type="password" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
</form>

<p class="mt-3">
    Don’t have an account?
    <a href="/Auth/Register">Create one</a>
</p>