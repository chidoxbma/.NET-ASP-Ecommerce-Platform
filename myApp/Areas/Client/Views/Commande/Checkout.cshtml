@model myApp.Areas.Client.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="container-fluid">
    <h2 class="mb-3">Checkout</h2>

    <h4>Cart Summary</h4>
    @if (Model.Items is null || !Model.Items.Any())
    {
        <div class="alert alert-info">Your cart is empty.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.NomProduit</td>
                            <td>@item.Quantite</td>
                            <td>@item.SousTotal</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <h4>Total: @Model.Total</h4>
    }

    <form method="post" asp-area="Client" asp-controller="Commande" asp-action="Confirmer" class="mt-4">
        @Html.AntiForgeryToken()

        <div class="form-group mb-3">
            <label asp-for="AdresseLivraison" class="form-label"></label>
            <input asp-for="AdresseLivraison" class="form-control" />
            <span asp-validation-for="AdresseLivraison" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="VilleLivraison" class="form-label"></label>
            <input asp-for="VilleLivraison" class="form-control" />
            <span asp-validation-for="VilleLivraison" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Confirm Order</button>
        <a asp-area="Client" asp-controller="Panier" asp-action="Index" class="btn btn-outline-secondary ms-2">Back to Cart</a>
    </form>
</div>