@model myApp.Areas.Client.ViewModels.PanierIndexViewModel

@{
    ViewData["Title"] = "Panier";
}

<div class="container-fluid">
    <h2 class="mb-3">Client - Panier</h2>

    @if (Model.Panier is null || Model.Panier.LignePaniers is null || !Model.Panier.LignePaniers.Any())
    {
        <div class="alert alert-info">Your cart is empty.</div>

        <a asp-area="Client"
           asp-controller="Produit"
           asp-action="Index"
           class="btn btn-outline-primary">
            Continue Shopping
        </a>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Unit Price</th>
                        <th style="min-width: 260px;">Quantity</th>
                        <th>Subtotal</th>
                        <th style="min-width: 130px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ligne in Model.Panier.LignePaniers)
                    {
                        <tr>
                            <td>@ligne.Produit.Nom</td>
                            <td>@ligne.Produit.Prix</td>
                            <td>
                                <form method="post"
                                      asp-area="Client"
                                      asp-controller="Panier"
                                      asp-action="ModifierQuantite"
                                      class="d-flex flex-wrap gap-2 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="lignePanierId" value="@ligne.Id" />

                                    <button type="submit" name="quantite" value="@(ligne.Quantite - 1)" class="btn btn-outline-secondary btn-sm">-</button>

                                    <input type="number"
                                           name="quantite"
                                           value="@ligne.Quantite"
                                           min="0"
                                           class="form-control form-control-sm"
                                           style="max-width: 80px;" />

                                    <button type="submit" name="quantite" value="@(ligne.Quantite + 1)" class="btn btn-outline-secondary btn-sm">+</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Update</button>
                                </form>
                            </td>
                            <td>@(ligne.Quantite * ligne.Produit.Prix)</td>
                            <td>
                                <form method="post" asp-area="Client" asp-controller="Panier" asp-action="Supprimer">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="lignePanierId" value="@ligne.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-3">
            <h4 class="mb-0">Total: @Model.Total</h4>

            <div class="d-flex flex-wrap gap-2">
                <a asp-area="Client" asp-controller="Produit" asp-action="Index" class="btn btn-outline-primary">Continue Shopping</a>
                <a asp-area="Client" asp-controller="Commande" asp-action="Checkout" class="btn btn-success">Proceed to Checkout</a>
            </div>
        </div>
    }
</div>