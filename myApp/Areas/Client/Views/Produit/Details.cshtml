@model myApp.Models.Produit

@{
    ViewData["Title"] = "Détails produit";
}

<h2>Détails du produit</h2>

<div class="card p-3 p-md-4 mb-3 product-details-card">
    <div class="row g-4 align-items-start">
        <div class="col-12 col-lg-5">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="product-details-image-wrap">
                    <img src="@Model.ImageUrl" alt="@Model.Nom" class="img-fluid rounded product-details-image" loading="lazy" />
                </div>
            }
        </div>
        <div class="col-12 col-lg-7">
            <p class="mb-2"><strong>Nom:</strong> @Model.Nom</p>
            <p class="mb-2"><strong>Prix:</strong> @Model.Prix</p>
            <p class="mb-0"><strong>Catégorie:</strong> @Model.Categorie?.Nom</p>
        </div>
    </div>
</div>

<form method="post" asp-area="Client" asp-controller="Panier" asp-action="Add" class="mb-3">
    <input type="hidden" name="produitId" value="@Model.Id" />

    <div class="mb-2">
        <label for="quantite">Quantity</label>
        <input id="quantite" name="quantite" type="number" min="1" value="1" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Add to Cart</button>
</form>

<a asp-area="Client" asp-controller="Produit" asp-action="Index" class="btn btn-secondary">Back to Products</a>
