@page "{id:int}"
@model myApp.Areas.Admin.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<h2 class="mb-3">Delete Product</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this product?
</div>

<dl class="row">
    <dt class="col-sm-2">Image</dt>
    <dd class="col-sm-10">
        @if (!string.IsNullOrWhiteSpace(Model.Produit.ImageUrl))
        {
            <img src="@Model.Produit.ImageUrl" alt="@Model.Produit.Nom" style="max-height: 120px;" class="img-thumbnail" />
        }
    </dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Produit.Nom</dd>

    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Produit.Prix</dd>

    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Produit.Categorie?.Nom</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Produit.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
