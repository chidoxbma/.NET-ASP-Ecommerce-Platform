@page "{id:int}"
@model myApp.Areas.Admin.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
}

<h2 class="mb-3">Edit Product</h2>

<form method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Produit.Id" />

    <div class="mb-3">
        <label asp-for="Produit.Nom" class="form-label"></label>
        <input asp-for="Produit.Nom" class="form-control" />
        <span asp-validation-for="Produit.Nom" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Produit.Prix" class="form-label"></label>
        <input asp-for="Produit.Prix" class="form-control" />
        <span asp-validation-for="Produit.Prix" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Produit.CategorieId" class="form-label">Category</label>
        <select asp-for="Produit.CategorieId" asp-items="Model.Categories" class="form-select"></select>
        <span asp-validation-for="Produit.CategorieId" class="text-danger"></span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Produit.ImageUrl))
    {
        <div class="mb-3">
            <label class="form-label">Current Image</label>
            <div>
                <img src="@Model.Produit.ImageUrl" alt="@Model.Produit.Nom" style="max-height: 120px;" class="img-thumbnail" />
            </div>
        </div>
    }

    <div class="mb-3">
        <label asp-for="ImageFile" class="form-label">Replace Image</label>
        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
        <span asp-validation-for="ImageFile" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
