@using Microsoft.AspNetCore.Identity
@using myApp.Models
@inject SignInManager<Utilisateur> SignInManager
@inject UserManager<Utilisateur> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var role = User.IsInRole("Admin") ? "Admin" : "Client";

    <li class="nav-item">
        <span class="nav-link text-dark">Hello @User.Identity?.Name (@role)</span>
    </li>

    @if (User.IsInRole("Admin"))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Admin" asp-page="/Index">Admin Panel</a>
        </li>
    }

    <li class="nav-item">
        <form method="post" action="/Auth/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Login">Login</a>
    </li>
}
</ul>
